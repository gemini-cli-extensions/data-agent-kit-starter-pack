{
  "name": "@google/standalone-notebook-mcp",
  "version": "0.1.0",
  "description": "Standalone MCP server for notebook manipulation",
  "main": "server.ts",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild server.ts --bundle --platform=node --outfile=dist/index.js --banner:js=\"#!/usr/bin/env node\"",
    "prepublishOnly": "npm run build",
    "start": "tsx server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tsx": "^4.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.4",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  }
}
