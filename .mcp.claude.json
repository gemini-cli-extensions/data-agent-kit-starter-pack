{
  "mcpServers": {
    "notebook_and_visualization": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp/dist/index.js"
      ],
      "env": {},
      "env_vars": [
        "DATA_CLOUD_CURR_IDE_NAME"
      ]
    },
    "datacloud_bigquery_toolbox": {
      "command": "npx",
      "args": [
        "-y",
        "@toolbox-sdk/server@>=1.1.0",
        "--prebuilt",
        "bigquery",
        "--stdio",
        "--user-agent-metadata",
        "datacloud.claude-and-codex"
      ],
      "env": {
        "BIGQUERY_LOCATION": "",
        "BIGQUERY_PROJECT": ""
      }
    },
    "datacloud_spanner_toolbox": {
      "command": "npx",
