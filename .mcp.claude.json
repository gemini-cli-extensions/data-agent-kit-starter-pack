        "datacloud.claude-and-codex"
      ],
      "env": {
        "SPANNER_DATABASE": "",
        "SPANNER_DIALECT": "",
        "SPANNER_INSTANCE": "",
        "SPANNER_PROJECT": ""
      }
    },
